FLASK_DEBUG=true

# Ports — change these if anything conflicts on your machine
APP_PORT=8000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093

# Postgres
DATABASE_NAME=hackathon_db
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis — use "redis" inside Docker, "localhost" for local dev without Docker
REDIS_HOST=redis
REDIS_PORT=6379

# Grafana
GRAFANA_PASSWORD=admin

# Discord alerts (optional)
# Get a webhook URL from your Discord server: Server Settings → Integrations → Webhooks
# Format: https://discord.com/api/webhooks/<id>/<token>
DISCORD_WEBHOOK_URL=
